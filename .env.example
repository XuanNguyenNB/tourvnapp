# ==============================================
# TourVN Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ---------------------------------------------
# Firebase Configuration (Optional)
# ---------------------------------------------
# Note: Firebase mobile API keys in firebase_options.dart are SAFE to commit
# These variables are for additional configuration only

# FIREBASE_API_KEY_ANDROID=your_android_api_key_here
# FIREBASE_API_KEY_IOS=your_ios_api_key_here
# FIREBASE_PROJECT_ID=tourvn-mobile-2026

# ---------------------------------------------
# Third-party API Keys (Add as needed)
# ---------------------------------------------
# GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# STRIPE_PUBLISHABLE_KEY=your_stripe_key_here
# PAYMENT_GATEWAY_KEY=your_payment_key_here

# ---------------------------------------------
# App Configuration
# ---------------------------------------------
# APP_ENV=development
# API_BASE_URL=https://api.yourdomain.com
# ENABLE_ANALYTICS=true
# DEBUG_MODE=true

# ---------------------------------------------
# Feature Flags
# ---------------------------------------------
# FEATURE_PAYMENT_ENABLED=false
# FEATURE_SOCIAL_LOGIN=true
# FEATURE_PUSH_NOTIFICATIONS=true
